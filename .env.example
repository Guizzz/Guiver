# EventBus — comunicazione interna in-process (nessun broker esterno)
# MQTT (opzionale) — broker esterno per ESP
# MQTT_BROKER_URL=mqtt://localhost:1883

# WebSocket ports
WSS_CLI_PORT=8081
WSS_MDL_PORT=8082

# API
API_PORT=8080

# Info point (UDP)
INFO_PORT=54321

# MQTT (Mosquitto broker)
MQTT_BROKER_URL=mqtt://localhost:1883

# External API keys
WEATHER_KEY=your_openweathermap_api_key
